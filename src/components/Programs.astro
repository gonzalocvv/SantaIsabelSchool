---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import Section from './Section.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const pr = t.programs;
---

<Section id="programs" class="bg-primary-50">
  <div class="mx-auto max-w-3xl text-center">
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-accent-700">{pr.eyebrow}</p>
    <h2 class="mt-3 text-3xl sm:text-4xl">{pr.title}</h2>
  </div>

  <div class="mt-12 grid gap-6 md:grid-cols-2">
    {
      pr.items.map((item, i) => (
        <article
          class="reveal rounded-card border border-edge bg-surface p-7 shadow-soft sm:p-8"
          data-reveal-delay={(i % 2) * 80}
        >
          <h3 class="text-2xl text-primary">{item.title}</h3>
          <p class="mt-3 leading-relaxed text-ink/80">{item.text}</p>
          <ul class="mt-5 space-y-2.5">
            {item.points.map((pt) => (
              <li class="flex items-start gap-3 text-ink/80">
                <svg class="mt-1 h-4 w-4 flex-none text-accent-700" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.7 5.3a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0L3.3 9.7a1 1 0 1 1 1.4-1.4l3.1 3.1 6.8-6.8a1 1 0 0 1 1.4 0z" clip-rule="evenodd" />
                </svg>
                <span>{pt}</span>
              </li>
            ))}
          </ul>
        </article>
      ))
    }
  </div>
</Section>
