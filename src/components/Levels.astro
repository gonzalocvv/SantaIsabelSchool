---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import Section from './Section.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const l = t.levels;
---

<Section id="levels" class="bg-cream">
  <div class="mx-auto max-w-3xl text-center">
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-accent-700">{l.eyebrow}</p>
    <h2 class="mt-3 text-3xl sm:text-4xl">{l.title}</h2>
    <p class="mt-5 text-lg text-muted">{l.intro}</p>
    <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
      <span class="text-sm font-semibold uppercase tracking-wide text-muted">{l.modalitiesLabel}:</span>
      {
        l.modalities.map((m) => (
          <span class="rounded-full border border-primary/20 bg-surface px-4 py-1.5 text-sm font-medium text-primary">
            {m}
          </span>
        ))
      }
    </div>
  </div>

  <ol class="relative mt-14 grid gap-y-8 gap-x-6 sm:grid-cols-2 lg:grid-cols-4">
    <!-- línea conectora (solo desktop) -->
    <div class="absolute left-0 right-0 top-5 hidden h-0.5 bg-edge lg:block" aria-hidden="true"></div>
    {
      l.items.map((item, i) => (
        <li class="reveal relative" data-reveal-delay={(i % 4) * 70}>
          <span class="relative z-10 flex h-10 w-10 items-center justify-center rounded-full bg-primary font-serif font-bold text-white ring-4 ring-cream">
            {i + 1}
          </span>
          <div class="mt-4 flex h-[calc(100%-3.5rem)] flex-col rounded-card border border-edge bg-surface p-6 shadow-soft">
            <div class="flex flex-wrap items-center gap-2">
              <h3 class="text-xl text-primary">{item.name}</h3>
              {item.tag && (
                <span class="rounded-full bg-secondary/10 px-2.5 py-0.5 text-xs font-semibold text-secondary">
                  {item.tag}
                </span>
              )}
            </div>
            <p class="mt-3 leading-relaxed text-ink/80">{item.desc}</p>
          </div>
        </li>
      ))
    }
  </ol>
</Section>
