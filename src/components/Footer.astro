---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import { site, isTodo } from '../data/site';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();

const navLinks = [
  { href: '#about', label: t.nav.about },
  { href: '#pillars', label: t.nav.proposal },
  { href: '#levels', label: t.nav.levels },
  { href: '#programs', label: t.nav.programs },
  { href: '#gallery', label: t.nav.gallery },
  { href: '#contact', label: t.nav.contact },
];
---

<footer class="border-t border-edge bg-cream">
  <div class="container-site py-12">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <div class="sm:col-span-2 lg:col-span-2">
        <p class="font-serif text-2xl font-bold text-primary">Santa Isabel School</p>
        <p class="mt-3 max-w-sm text-muted">{t.footer.tagline}</p>
        <p class="mt-4 text-sm text-muted">
          {site.location.city}, {site.location.region} · Uruguay
        </p>
      </div>

      <nav aria-label={t.footer.navTitle}>
        <h2 class="text-sm font-semibold uppercase tracking-wide text-primary">{t.footer.navTitle}</h2>
        <ul class="mt-3 space-y-2">
          {
            navLinks.map((l) => (
              <li>
                <a href={l.href} class="text-muted transition-colors hover:text-primary">{l.label}</a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wide text-primary">{t.footer.followTitle}</h2>
        <ul class="mt-3 space-y-2">
          <li>
            <a
              href={site.social.instagram}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-muted transition-colors hover:text-primary"
            >
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="5" />
                <circle cx="12" cy="12" r="4" />
                <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor" stroke="none" />
              </svg>
              {site.social.instagramHandle}
            </a>
          </li>
          {
            !isTodo(site.contact.email) && (
              <li>
                <a href={`mailto:${site.contact.email}`} class="text-muted transition-colors hover:text-primary">
                  {site.contact.email}
                </a>
              </li>
            )
          }
        </ul>
      </div>
    </div>

    <div class="mt-10 border-t border-edge pt-6 text-sm text-muted">
      © {year} {site.name} · {site.legalName}. {t.footer.rights}
    </div>
  </div>
</footer>
