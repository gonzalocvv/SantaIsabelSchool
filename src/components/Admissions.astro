---
// Proceso de admisión en 3 pasos: guía a las familias interesadas hacia la
// conversión (formulario o WhatsApp). Sin requisitos ni fechas inventadas.
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import Section from './Section.astro';
import Button from './Button.astro';
import { site, isTodo, whatsappLink } from '../data/site';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const a = t.admissions;
const waReady = !isTodo(site.contact.whatsapp);
---

<Section id="admissions" class="border-y border-edge bg-surface">
  <div class="mx-auto max-w-3xl text-center">
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-accent-700">{a.eyebrow}</p>
    <h2 class="mt-3 text-3xl sm:text-4xl">{a.title}</h2>
    <p class="mt-5 text-lg text-muted">{a.intro}</p>
  </div>

  <ol class="relative mt-12 grid gap-10 sm:grid-cols-3 sm:gap-8" data-reveal-group>
    <!-- Conector entre pasos (solo desktop) -->
    <div
      class="pointer-events-none absolute left-[16.66%] right-[16.66%] top-7 hidden border-t-2 border-dashed border-edge sm:block"
      aria-hidden="true"
    >
    </div>
    {
      a.steps.map((step) => (
        <li class="reveal relative flex flex-col items-center text-center">
          <span class="flex h-14 w-14 items-center justify-center rounded-full bg-primary font-serif text-xl font-semibold text-accent-300 shadow-soft ring-8 ring-surface">
            {step.n}
          </span>
          <h3 class="mt-5 text-2xl">{step.title}</h3>
          <p class="mt-2 max-w-xs text-muted">{step.text}</p>
        </li>
      ))
    }
  </ol>

  <div class="reveal mt-12 flex flex-col items-center justify-center gap-3 sm:flex-row">
    <Button href="#contact">{a.cta}</Button>
    {
      waReady && (
        <Button
          href={whatsappLink(t.contact.whatsappPrefill)}
          target="_blank"
          rel="noopener noreferrer"
          variant="whatsapp"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.7 4.8-1.3A10 10 0 1 0 12 2zm5.8 14.2c-.2.7-1.4 1.3-2 1.4-.5.1-1.2.1-1.9-.1-.4-.1-1-.3-1.7-.6-3-1.3-4.9-4.3-5-4.5-.2-.2-1.2-1.6-1.2-3s.7-2.1 1-2.4c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.5l.8 2c.1.2.1.4 0 .5l-.4.6c-.2.2-.3.4-.1.7.2.3.8 1.4 1.8 2.2 1.2 1.1 2.2 1.4 2.5 1.5.2.1.4.1.6-.1l.7-.9c.2-.2.4-.2.6-.1l1.9.9c.3.1.4.2.5.3 0 .2 0 .8-.2 1.5z" />
          </svg>
          {a.ctaWhatsapp}
        </Button>
      )
    }
  </div>
</Section>
