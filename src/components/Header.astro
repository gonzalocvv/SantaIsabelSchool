---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import LanguageSwitch from './LanguageSwitch.astro';
import Button from './Button.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const links = [
  { href: '#about', label: t.nav.about },
  { href: '#pillars', label: t.nav.proposal },
  { href: '#levels', label: t.nav.levels },
  { href: '#programs', label: t.nav.programs },
  { href: '#gallery', label: t.nav.gallery },
  { href: '#contact', label: t.nav.contact },
];
---

<header class="sticky top-0 z-50 border-b border-edge/70 bg-cream/85 backdrop-blur">
  <nav class="container-site flex h-16 items-center justify-between gap-4" aria-label={t.nav.primary}>
    <a href={lang === 'es' ? '/' : '/en/'} class="flex items-center gap-2">
      <span class="font-serif text-xl font-bold leading-none text-primary sm:text-2xl"
        >Santa Isabel</span
      >
      <span class="hidden text-sm font-semibold uppercase tracking-wide text-accent-700 sm:inline"
        >School</span
      >
    </a>

    <!-- Desktop -->
    <div class="hidden items-center gap-6 lg:flex">
      <ul class="flex items-center gap-5">
        {
          links.map((l) => (
            <li>
              <a href={l.href} class="text-sm font-medium text-ink/80 transition-colors hover:text-primary">
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
      <LanguageSwitch lang={lang} />
      <Button href="#contact" class="!px-5 !py-2 text-sm">{t.nav.cta}</Button>
    </div>

    <!-- Mobile (details/summary, sin JS; el script de abajo solo agrega cierres extra) -->
    <details class="group relative lg:hidden" data-mobile-menu>
      <summary
        class="flex h-10 w-10 cursor-pointer list-none items-center justify-center rounded-md border border-edge text-primary [&::-webkit-details-marker]:hidden"
        aria-label={t.nav.menu}
      >
        <svg class="h-6 w-6 group-open:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" d="M4 7h16M4 12h16M4 17h16" />
        </svg>
        <svg class="hidden h-6 w-6 group-open:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" d="M6 6l12 12M18 6L6 18" />
        </svg>
      </summary>
      <div class="absolute right-0 mt-2 w-64 rounded-card border border-edge bg-surface p-4 shadow-lift">
        <ul class="flex flex-col gap-1">
          {
            links.map((l) => (
              <li>
                <a
                  href={l.href}
                  onclick="this.closest('details').open=false"
                  class="block rounded-md px-3 py-2 text-base font-medium text-ink hover:bg-primary/5 hover:text-primary"
                >
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
        <div class="mt-3 flex items-center justify-between border-t border-edge pt-3">
          <LanguageSwitch lang={lang} />
          <Button href="#contact" onclick="this.closest('details').open=false" class="!px-4 !py-2 text-sm">{t.nav.cta}</Button>
        </div>
      </div>
    </details>
  </nav>
</header>

<script>
  // Cierres extra del menú móvil: Escape (devuelve el foco al botón) y clic afuera.
  const menu = document.querySelector<HTMLDetailsElement>('details[data-mobile-menu]');
  if (menu) {
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menu.open) {
        menu.open = false;
        menu.querySelector('summary')?.focus();
      }
    });
    document.addEventListener('pointerdown', (e) => {
      if (menu.open && !menu.contains(e.target as Node)) menu.open = false;
    });
  }
</script>
