---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import Section from './Section.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const p = t.pillars;
---

<Section id="pillars" class="bg-surface">
  <div class="mx-auto max-w-3xl text-center">
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-accent-700">{p.eyebrow}</p>
    <h2 class="mt-3 text-3xl sm:text-4xl">{p.title}</h2>
    <p class="mt-5 text-lg text-muted">{p.intro}</p>
  </div>

  <div class="mt-12 grid gap-6 sm:grid-cols-2">
    {
      p.items.map((item, i) => (
        <article
          class="reveal group rounded-card border border-edge bg-cream/60 p-7 transition duration-300 ease-out-soft hover:-translate-y-1 hover:shadow-lift"
          data-reveal-delay={(i % 2) * 80}
        >
          <span class="text-sm font-bold uppercase tracking-[0.2em] text-accent-700">{item.n}</span>
          <h3 class="mt-1 text-xl text-primary">{item.title}</h3>
          <p class="mt-3 leading-relaxed text-ink/80">{item.text}</p>
        </article>
      ))
    }
  </div>
</Section>
