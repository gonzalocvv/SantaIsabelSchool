---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import { Image } from 'astro:assets';
import Section from './Section.astro';
import crest from '../assets/img/post-03.jpg';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const a = t.about;

const shieldIcons: Record<string, string> = {
  puente: 'M3 16c3-4 15-4 18 0M5 16v3M19 16v3M9 16v3M15 16v3',
  sol: 'M12 4v2M12 18v2M4 12H2M22 12h-2M6 6 4.5 4.5M18 6l1.5-1.5M12 8a4 4 0 1 1 0 8',
  escudo: 'M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z',
};
---

<Section id="about" class="bg-cream">
  <div class="grid items-start gap-10 lg:grid-cols-2 lg:gap-16">
    <div class="reveal">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-accent-700">{a.eyebrow}</p>
      <h2 class="mt-3 text-3xl sm:text-4xl">{a.title}</h2>
      <div class="mt-6 space-y-4 text-lg leading-relaxed text-ink/85">
        {a.history.map((p) => <p>{p}</p>)}
      </div>
      <figure class="mt-8 border-l-4 border-accent bg-surface/60 py-3 pl-5 pr-4">
        <blockquote class="font-serif text-xl italic text-primary">“{a.mission}”</blockquote>
        <figcaption class="mt-1 text-sm font-semibold uppercase tracking-wide text-muted">
          {a.missionLabel}
        </figcaption>
      </figure>
    </div>

    <div class="reveal" data-reveal-delay="120">
      <div class="rounded-card border border-edge bg-surface p-6 shadow-soft sm:p-8">
        <div class="mx-auto max-w-[260px] rounded-card bg-cream p-4">
          <Image
            src={crest}
            alt={lang === 'es' ? 'Logo de Santa Isabel School' : 'Santa Isabel School logo'}
            widths={[360, 520]}
            sizes="260px"
            class="h-auto w-full object-contain"
          />
        </div>
        <h3 class="mt-6 text-center text-2xl">{a.shield.title}</h3>
        <ul class="mt-6 space-y-5">
          {
            a.shield.items.map((it) => (
              <li class="flex gap-4">
                <span class="flex h-10 w-10 flex-none items-center justify-center rounded-full bg-primary/5 text-primary">
                  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d={shieldIcons[it.key]} />
                  </svg>
                </span>
                <div>
                  <p class="font-semibold text-primary">{it.label}</p>
                  <p class="text-muted">{it.text}</p>
                </div>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</Section>
