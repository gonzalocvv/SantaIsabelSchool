---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import Section from './Section.astro';
import Button from './Button.astro';
import { site, isTodo, whatsappLink, telLink } from '../data/site';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const c = t.contact;

const accessKey = site.forms.web3formsAccessKey;
const formReady = !isTodo(accessKey);
const waReady = !isTodo(site.contact.whatsapp);
const phoneReady = !isTodo(site.contact.phone);

const info = [
  { label: c.labels.address, value: site.contact.address },
  { label: c.labels.phone, value: site.contact.phone },
  { label: c.labels.email, value: site.contact.email },
  { label: c.labels.hours, value: site.contact.hours },
];
const pending = lang === 'es' ? 'A confirmar' : 'To be confirmed';
---

<Section id="contact" class="bg-primary text-white">
  <div class="grid gap-10 lg:grid-cols-2 lg:gap-16">
    <!-- Columna izquierda: intro + form -->
    <div class="reveal">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-accent">{c.eyebrow}</p>
      <h2 class="mt-3 text-3xl text-white sm:text-4xl">{c.title}</h2>
      <p class="mt-5 max-w-md text-lg text-white/80">{c.intro}</p>

      <form id="contact-form" class="mt-8 space-y-4" novalidate>
        <input type="hidden" name="access_key" value={accessKey} />
        <input type="hidden" name="subject" value={`Consulta web — ${site.name}`} />
        <input type="hidden" name="from_name" value={site.name} />
        <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" />

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="cf-name" class="block text-sm font-medium text-white/90">
              {c.form.name} <span class="text-accent" aria-hidden="true">*</span>
            </label>
            <input
              id="cf-name"
              name="name"
              type="text"
              required
              autocomplete="name"
              class="mt-1 w-full rounded-lg border border-white/30 bg-white/[0.13] px-3 py-2.5 text-white placeholder-white/70 focus:border-accent focus:bg-white/15"
            />
          </div>
          <div>
            <label for="cf-email" class="block text-sm font-medium text-white/90">
              {c.form.email} <span class="text-accent" aria-hidden="true">*</span>
            </label>
            <input
              id="cf-email"
              name="email"
              type="email"
              required
              autocomplete="email"
              class="mt-1 w-full rounded-lg border border-white/30 bg-white/[0.13] px-3 py-2.5 text-white placeholder-white/70 focus:border-accent focus:bg-white/15"
            />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="cf-phone" class="block text-sm font-medium text-white/90">{c.form.phone}</label>
            <input
              id="cf-phone"
              name="phone"
              type="tel"
              autocomplete="tel"
              class="mt-1 w-full rounded-lg border border-white/30 bg-white/[0.13] px-3 py-2.5 text-white placeholder-white/70 focus:border-accent focus:bg-white/15"
            />
          </div>
          <div>
            <label for="cf-level" class="block text-sm font-medium text-white/90">{c.form.level}</label>
            <select
              id="cf-level"
              name="level"
              class="mt-1 w-full rounded-lg border border-white/30 bg-white/[0.13] px-3 py-2.5 text-white focus:border-accent focus:bg-white/15"
            >
              <option value="" disabled selected>{c.form.level}</option>
              {c.form.levelOptions.map((opt) => <option class="text-ink" value={opt}>{opt}</option>)}
            </select>
          </div>
        </div>

        <div>
          <label for="cf-message" class="block text-sm font-medium text-white/90">
            {c.form.message} <span class="text-accent" aria-hidden="true">*</span>
          </label>
          <textarea
            id="cf-message"
            name="message"
            rows="4"
            required
            placeholder={c.form.messagePlaceholder}
            class="mt-1 w-full rounded-lg border border-white/30 bg-white/[0.13] px-3 py-2.5 text-white placeholder-white/70 focus:border-accent focus:bg-white/15"
          ></textarea>
        </div>

        <button
          type="submit"
          class="inline-flex w-full items-center justify-center gap-2 rounded-full bg-accent px-6 py-3 text-base font-semibold text-primary-700 shadow-soft transition duration-200 ease-out-soft hover:bg-accent-600 active:scale-[0.98] disabled:cursor-not-allowed sm:w-auto"
        >
          <span data-label-idle>{c.form.submit}</span>
          <span data-label-sending class="hidden">{c.form.sending}</span>
        </button>

        <p
          id="cf-status"
          class="hidden rounded-lg px-4 py-3 text-sm"
          role="status"
          aria-live="polite"
        ></p>

        {!formReady && (
          <p class="text-sm text-white/60">{c.pendingNote}</p>
        )}
      </form>
    </div>

    <!-- Columna derecha: datos + WhatsApp + mapa -->
    <div class="reveal space-y-6" data-reveal-delay="120">
      <div class="rounded-card bg-white/10 p-6">
        <dl class="space-y-4">
          {
            info.map((row) => (
              <div class="flex flex-col gap-0.5">
                <dt class="text-xs font-semibold uppercase tracking-wide text-accent-300">{row.label}</dt>
                <dd class="text-white/90">{isTodo(row.value) ? pending : row.value}</dd>
              </div>
            ))
          }
        </dl>
        <div class="mt-6 flex flex-wrap gap-3">
          <Button
            href={waReady ? whatsappLink() : undefined}
            variant="whatsapp"
            disabled={!waReady}
            aria-disabled={!waReady ? 'true' : undefined}
            class={waReady ? '' : 'opacity-60 cursor-not-allowed'}
          >
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.7 4.8-1.3A10 10 0 1 0 12 2zm5.8 14.2c-.2.7-1.4 1.3-2 1.4-.5.1-1.2.1-1.9-.1-.4-.1-1-.3-1.7-.6-3-1.3-4.9-4.3-5-4.5-.2-.2-1.2-1.6-1.2-3s.7-2.1 1-2.4c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.5l.8 2c.1.2.1.4 0 .5l-.4.6c-.2.2-.3.4-.1.7.2.3.8 1.4 1.8 2.2 1.2 1.1 2.2 1.4 2.5 1.5.2.1.4.1.6-.1l.7-.9c.2-.2.4-.2.6-.1l1.9.9c.3.1.4.2.5.3 0 .2 0 .8-.2 1.5z" />
            </svg>
            {c.whatsappCta}
          </Button>
          {phoneReady && (
            <Button href={telLink()} variant="outline" class="!border-white/30 !text-white hover:!bg-white/10">
              {c.callCta}
            </Button>
          )}
        </div>
      </div>

      <div class="overflow-hidden rounded-card bg-white/10">
        {
          !isTodo(site.contact.mapsEmbedSrc) ? (
            <iframe
              src={site.contact.mapsEmbedSrc}
              title={lang === 'es' ? 'Mapa del colegio' : 'School map'}
              class="aspect-video w-full"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            />
          ) : (
            <div class="flex aspect-video w-full flex-col items-center justify-center gap-2 text-center text-white/60">
              <svg class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
                <path d="M12 21s-7-5.5-7-11a7 7 0 1 1 14 0c0 5.5-7 11-7 11z" />
                <circle cx="12" cy="10" r="2.5" />
              </svg>
              <span class="text-sm">{pending}</span>
            </div>
          )
        }
      </div>
    </div>
  </div>
</Section>

<script is:inline define:vars={{ formReady, successMsg: c.form.success, errorMsg: c.form.error }}>
  (() => {
    const form = document.getElementById('contact-form');
    if (!form) return;
    const status = document.getElementById('cf-status');
    const btn = form.querySelector('button[type="submit"]');
    const idle = form.querySelector('[data-label-idle]');
    const sending = form.querySelector('[data-label-sending]');

    const setStatus = (msg, ok) => {
      status.textContent = msg;
      status.classList.remove('hidden');
      status.classList.toggle('bg-whatsapp/20', ok);
      status.classList.toggle('text-white', true);
      status.classList.toggle('bg-red-500/25', !ok);
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form.reportValidity()) return;

      if (!formReady) {
        setStatus(errorMsg, false);
        return;
      }

      btn.disabled = true;
      idle.classList.add('hidden');
      sending.classList.remove('hidden');

      try {
        const data = new FormData(form);
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: data,
        });
        const json = await res.json();
        if (res.ok && json.success) {
          form.reset();
          setStatus(successMsg, true);
        } else {
          setStatus(errorMsg, false);
        }
      } catch {
        setStatus(errorMsg, false);
      } finally {
        btn.disabled = false;
        idle.classList.remove('hidden');
        sending.classList.add('hidden');
      }
    });
  })();
</script>
