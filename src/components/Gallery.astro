---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import { Image } from 'astro:assets';
import Section from './Section.astro';
import Button from './Button.astro';
import { site } from '../data/site';
// Las 3 fotos son un único panorama partido para el feed de Instagram
// ("EN MOVIMIENTO"). Orden de izquierda a derecha: 10 → 11 → 12.
import slice1 from '../assets/img/post-10.jpg';
import slice2 from '../assets/img/post-11.jpg';
import slice3 from '../assets/img/post-12.jpg';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const g = t.gallery;

const slices = [slice1, slice2, slice3];
const panoramaAlt =
  lang === 'es'
    ? 'Estudiantes de Santa Isabel School jugando al aire libre en el patio.'
    : 'Santa Isabel School students playing outdoors in the playground.';
const igCta = lang === 'es' ? 'Seguinos en Instagram' : 'Follow us on Instagram';
---

<Section id="gallery" class="bg-cream">
  <div class="mx-auto max-w-3xl text-center">
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-accent-700">{g.eyebrow}</p>
    <h2 class="mt-3 text-3xl sm:text-4xl">{g.title}</h2>
    <p class="mt-5 text-lg text-muted">{g.intro}</p>
  </div>

  <!-- Panorama: 3 recortes del feed como una sola imagen continua (3 col en todos los tamaños) -->
  <figure
    class="reveal mt-10 grid grid-cols-3 overflow-hidden rounded-card border border-edge shadow-soft"
    role="img"
    aria-label={panoramaAlt}
  >
    {
      slices.map((src) => (
        <Image
          src={src}
          alt=""
          widths={[220, 420, 560]}
          sizes="(min-width: 1024px) 24rem, 33vw"
          class="block aspect-[4/5] h-full w-full object-cover"
        />
      ))
    }
  </figure>

  <div class="mt-8 flex justify-center">
    <Button href={site.social.instagram} target="_blank" rel="noopener noreferrer" variant="outline">
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
        <rect x="3" y="3" width="18" height="18" rx="5" />
        <circle cx="12" cy="12" r="4" />
        <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor" stroke="none" />
      </svg>
      {igCta}
    </Button>
  </div>
</Section>
