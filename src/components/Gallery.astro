---
// Galería / Instagram. El material vive en src/data/gallery.ts: hoy el
// panorama real del feed; cuando haya fotos limpias del colegio se cargan
// en `photos` y esta sección escala a grid + lightbox (ver nota en gallery.ts).
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import { Image } from 'astro:assets';
import Section from './Section.astro';
import Button from './Button.astro';
import { site } from '../data/site';
import { panoramaSlices } from '../data/gallery';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const g = useTranslations(lang).gallery;
---

<Section id="gallery" class="bg-cream">
  <div class="mx-auto max-w-3xl text-center">
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-accent-700">{g.eyebrow}</p>
    <h2 class="mt-3 text-3xl sm:text-4xl">{g.title}</h2>
    <p class="mt-5 text-lg text-muted">{g.intro}</p>
  </div>

  <!-- Panorama: 3 recortes del feed como una sola imagen continua; entra por
       partes (stagger) y se arma sola. Hover sutil en bloque (solo transform). -->
  <figure
    class="group mt-10 grid grid-cols-3 overflow-hidden rounded-card border border-edge shadow-soft"
    role="img"
    aria-label={g.panoramaAlt}
    data-reveal-group
  >
    {
      panoramaSlices.map((src) => (
        <div class="reveal overflow-hidden">
          <Image
            src={src}
            alt=""
            widths={[220, 420, 560]}
            sizes="(min-width: 1024px) 24rem, 33vw"
            class="block aspect-[4/5] h-full w-full object-cover transition-transform duration-500 ease-out-strong group-hover:scale-[1.02]"
          />
        </div>
      ))
    }
  </figure>

  <!-- Cita real del feed (caption del panorama) -->
  <blockquote class="reveal mx-auto mt-10 max-w-2xl text-center">
    <p class="font-serif text-2xl italic leading-snug text-primary sm:text-3xl">
      “{g.quote}”
    </p>
  </blockquote>

  <!-- CTA Instagram -->
  <div
    class="reveal mx-auto mt-10 flex max-w-xl flex-col items-center gap-4 rounded-card border border-edge bg-surface p-6 text-center shadow-soft sm:flex-row sm:text-left"
  >
    <span
      class="flex h-12 w-12 flex-none items-center justify-center rounded-full bg-primary/5 text-primary"
    >
      <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
        <rect x="3" y="3" width="18" height="18" rx="5" />
        <circle cx="12" cy="12" r="4" />
        <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor" stroke="none" />
      </svg>
    </span>
    <div class="flex-1">
      <p class="font-semibold text-primary">{site.social.instagramHandle}</p>
      <p class="mt-0.5 text-sm text-muted">{g.followText}</p>
    </div>
    <Button
      href={site.social.instagram}
      target="_blank"
      rel="noopener noreferrer"
      variant="outline"
      class="flex-none !px-5 !py-2.5 text-sm"
    >
      {g.followCta}
    </Button>
  </div>
</Section>
