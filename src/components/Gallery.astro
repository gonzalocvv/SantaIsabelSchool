---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import { Image } from 'astro:assets';
import Section from './Section.astro';
import { site } from '../data/site';
import post11 from '../assets/img/post-11.jpg';
import post12 from '../assets/img/post-12.jpg';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const g = t.gallery;

const photos = [
  {
    src: post12,
    alt:
      lang === 'es'
        ? 'Niña corriendo en el patio de césped del colegio.'
        : "A child running on the school's grassy playground.",
  },
  {
    src: post11,
    alt:
      lang === 'es'
        ? 'Niños jugando con globos en el patio de césped.'
        : 'Children playing with balloons on the grassy playground.',
  },
];
const igCta = lang === 'es' ? 'Seguinos en Instagram' : 'Follow us on Instagram';
const igSub = lang === 'es' ? 'Más momentos del día a día' : 'More everyday moments';
---

<Section id="gallery" class="bg-cream">
  <div class="mx-auto max-w-3xl text-center">
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-accent-700">{g.eyebrow}</p>
    <h2 class="mt-3 text-3xl sm:text-4xl">{g.title}</h2>
    <p class="mt-5 text-lg text-muted">{g.intro}</p>
  </div>

  <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {
      photos.map((ph, i) => (
        <figure
          class="reveal overflow-hidden rounded-card border border-edge bg-surface shadow-soft"
          data-reveal-delay={i * 80}
        >
          <Image
            src={ph.src}
            alt={ph.alt}
            widths={[400, 700]}
            sizes="(min-width: 1024px) 360px, (min-width: 640px) 45vw, 90vw"
            class="aspect-[4/5] w-full object-cover"
          />
        </figure>
      ))
    }
    <a
      href={site.social.instagram}
      target="_blank"
      rel="noopener noreferrer"
      class="reveal flex aspect-[4/5] flex-col items-center justify-center gap-3 rounded-card bg-primary p-6 text-center text-white shadow-soft transition duration-200 ease-out-soft hover:bg-primary-700"
      data-reveal-delay="160"
    >
      <svg class="h-10 w-10 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
        <rect x="3" y="3" width="18" height="18" rx="5" />
        <circle cx="12" cy="12" r="4" />
        <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor" stroke="none" />
      </svg>
      <span class="font-semibold">{igCta}</span>
      <span class="text-sm text-white/75">{igSub}</span>
    </a>
  </div>
</Section>
