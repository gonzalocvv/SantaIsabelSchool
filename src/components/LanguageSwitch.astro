---
import type { Lang } from '../i18n/ui';
import { useTranslations, homePath } from '../i18n/utils';
interface Props {
  lang: Lang;
  class?: string;
}
const { lang, class: extra = '' } = Astro.props;
const t = useTranslations(lang);
const linkBase = 'px-2 py-1 rounded text-sm font-semibold transition-colors';
---

<div class={`inline-flex items-center gap-1 ${extra}`} role="group" aria-label={t.langSwitch.label}>
  <a
    href={homePath('es')}
    hreflang="es"
    lang="es"
    aria-label={t.langSwitch.toEs}
    aria-current={lang === 'es' ? 'page' : undefined}
    class={`${linkBase} ${lang === 'es' ? 'bg-primary text-white' : 'text-muted hover:text-primary'}`}
  >
    {t.langSwitch.es}
  </a>
  <a
    href={homePath('en')}
    hreflang="en"
    lang="en"
    aria-label={t.langSwitch.toEn}
    aria-current={lang === 'en' ? 'page' : undefined}
    class={`${linkBase} ${lang === 'en' ? 'bg-primary text-white' : 'text-muted hover:text-primary'}`}
  >
    {t.langSwitch.en}
  </a>
</div>
