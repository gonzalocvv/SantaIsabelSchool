---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import { Image } from 'astro:assets';
import Button from './Button.astro';
import logo from '../assets/img/post-03.jpg';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="relative overflow-hidden bg-gradient-to-b from-cream to-surface">
  <!-- Motivo decorativo: sol naciente + arco (puente), eco del escudo -->
  <div class="pointer-events-none absolute inset-0 -z-0" aria-hidden="true">
    <svg
      class="absolute -right-24 -top-24 h-[28rem] w-[28rem] text-accent/15"
      viewBox="0 0 200 200"
      fill="none"
    >
      <circle cx="100" cy="100" r="60" fill="currentColor" />
      {
        Array.from({ length: 12 }).map((_, i) => (
          <rect
            x="98"
            y="6"
            width="4"
            height="22"
            rx="2"
            fill="currentColor"
            transform={`rotate(${i * 30} 100 100)`}
          />
        ))
      }
    </svg>
    <svg
      class="absolute bottom-0 left-0 h-40 w-full text-primary/5"
      viewBox="0 0 1200 120"
      preserveAspectRatio="none"
    >
      <path d="M0,120 Q300,20 600,60 T1200,40 L1200,120 Z" fill="currentColor" />
    </svg>
  </div>

  <div class="container-site relative z-10 grid items-center gap-12 py-20 sm:py-28 lg:grid-cols-[1.2fr_1fr] lg:py-32">
    <div class="max-w-2xl">
      <p class="reveal text-sm font-semibold uppercase tracking-[0.18em] text-accent-700">
        {t.hero.eyebrow}
      </p>
      <h1 class="reveal mt-4 text-4xl leading-[1.1] sm:text-5xl lg:text-6xl" data-reveal-delay="60">
        {t.hero.title}
      </h1>
      <p class="reveal mt-6 max-w-2xl text-lg text-muted sm:text-xl" data-reveal-delay="120">
        {t.hero.subtitle}
      </p>
      <div class="reveal mt-8 flex flex-col gap-3 sm:flex-row" data-reveal-delay="180">
        <Button href="#contact">{t.hero.ctaPrimary}</Button>
        <Button href="#pillars" variant="outline">{t.hero.ctaSecondary}</Button>
      </div>
      <ul class="reveal mt-10 flex flex-wrap gap-x-6 gap-y-3" data-reveal-delay="240">
        {
          t.hero.badges.map((b) => (
            <li class="flex items-center gap-2 text-sm font-medium text-ink/80">
              <svg class="h-5 w-5 flex-none text-secondary" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path
                  fill-rule="evenodd"
                  d="M16.7 5.3a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0L3.3 9.7a1 1 0 1 1 1.4-1.4l3.1 3.1 6.8-6.8a1 1 0 0 1 1.4 0z"
                  clip-rule="evenodd"
                />
              </svg>
              {b}
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Emblema institucional (logo real) -->
    <div class="reveal hidden justify-center lg:flex" data-reveal-delay="120">
      <div class="rounded-card border border-edge bg-surface p-8 shadow-soft">
        <Image
          src={logo}
          alt={lang === 'es' ? 'Logo de Santa Isabel School' : 'Santa Isabel School logo'}
          widths={[360, 560]}
          sizes="360px"
          loading="eager"
          fetchpriority="high"
          class="h-auto w-full max-w-[320px] object-contain"
        />
      </div>
    </div>
  </div>
</section>
